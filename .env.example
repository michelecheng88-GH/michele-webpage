# Supabase — get from your project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side only — NEVER expose to browser (used by admin server routes)
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin (Sprint 3, temporary until Supabase Auth in Sprint 5) ─────────────
ADMIN_PASSWORD=

# ── Email (Book a Call notifications, via Resend) ────────────────────────────
# Get a free key at https://resend.com → API Keys.
RESEND_API_KEY=
# Where Book-a-Call enquiries are emailed (defaults to m@thizworks.com).
CONTACT_NOTIFY_EMAIL=m@thizworks.com
# Sender — must be a verified Resend domain. onboarding@resend.dev works for
# testing but only delivers to your own Resend account email. To reliably reach
# m@thizworks.com, verify thizworks.com in Resend and use e.g.
# "Michele Cheng <notifications@thizworks.com>".
CONTACT_FROM_EMAIL=Michele Cheng Website <onboarding@resend.dev>

# ── Booking ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/30min

# ── App URL (used for redirect URLs) ────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
